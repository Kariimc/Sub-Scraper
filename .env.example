# Sub-Scraper — baked-in credentials (optional but recommended for a personal box).
#
# Copy this file to ".env" in the same folder and fill in your keys:
#     cp .env.example .env
#
# The app loads .env automatically on startup, so NOBODY has to type keys into
# the app — it opens already "logged in" and stays that way across restarts.
#
# .env is gitignored and never committed. On a host like Render you can instead
# set these same names in the dashboard's Environment section; real host
# environment variables override anything in this file.

# --- Spotify --- (get these at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- SoundCloud --- (token from your logged-in browser's oauth_token cookie)
SOUNDCLOUD_USERNAME=
SOUNDCLOUD_AUTH_TOKEN=
